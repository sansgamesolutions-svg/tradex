{
  "name": "mean-reversion",
  "version": "1.0",
  "description": "Buy oversold Bollinger Band touches; sell overbought. Lower thresholds for faster response.",
  "weights": {"model": 0.4, "ta": 0.6},
  "thresholds": {"ml_ta": 0.52, "ta_only": 0.60},
  "timeframes": {"primary": "1d", "confirmation": [], "require_alignment": false},
  "position_sizing": {"mode": "confidence_scaled", "base_cost": 500, "min_confidence": 0.15, "max_scale": 1.0},
  "risk": {
    "stop_loss_rate": 0.008,
    "take_profit_rate": 0.015,
    "max_drawdown_rate": 0.02,
    "daily_loss_limit_rate": 0.05,
    "max_open_positions": 2,
    "max_position_cost": 500.0
  },
  "gates": {
    "ta_confirmation": false,
    "trend":          {"enabled": false},
    "momentum":       {"enabled": false},
    "volume":         {"enabled": false},
    "volatility":     {"enabled": false},
    "mean_reversion": {"enabled": true, "require_bb_touch": true, "rsi_oversold": 35, "rsi_overbought": 65},
    "news":           {"enabled": false}
  }
}
