{
  "name": "multi-timeframe",
  "version": "1.0",
  "description": "Daily signal must align with weekly trend direction before acting.",
  "weights": {"model": 0.6, "ta": 0.4},
  "thresholds": {"ml_ta": 0.57, "ta_only": 0.67},
  "timeframes": {"primary": "1d", "confirmation": ["1w"], "require_alignment": true},
  "position_sizing": {"mode": "confidence_scaled", "base_cost": 500, "min_confidence": 0.3, "max_scale": 1.3},
  "risk": {
    "stop_loss_rate": 0.01,
    "take_profit_rate": 0.02,
    "max_drawdown_rate": 0.02,
    "daily_loss_limit_rate": 0.05,
    "max_open_positions": 2,
    "max_position_cost": 500.0
  },
  "gates": {
    "ta_confirmation": true,
    "trend":          {"enabled": true, "adx_min": 18.0, "require_supertrend": false},
    "momentum":       {"enabled": false},
    "volume":         {"enabled": false},
    "volatility":     {"enabled": false},
    "mean_reversion": {"enabled": false},
    "news":           {"enabled": false}
  }
}
