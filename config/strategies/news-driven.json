{
  "name": "news-driven",
  "version": "1.0",
  "description": "Block entries when Finnhub news sentiment opposes the signal direction. Requires TRADEX_FINNHUB_API_KEY.",
  "weights": {"model": 0.6, "ta": 0.4},
  "thresholds": {"ml_ta": 0.58, "ta_only": 0.68},
  "timeframes": {"primary": "1d", "confirmation": [], "require_alignment": false},
  "position_sizing": {"mode": "confidence_scaled", "base_cost": 500, "min_confidence": 0.2, "max_scale": 1.2},
  "gates": {
    "ta_confirmation": true,
    "trend":          {"enabled": false},
    "momentum":       {"enabled": false},
    "volume":         {"enabled": false},
    "volatility":     {"enabled": false},
    "mean_reversion": {"enabled": false},
    "news":           {"enabled": true, "lookback_hours": 24, "cache_ttl_minutes": 60}
  }
}
