{
  "name": "trend-following",
  "version": "1.0",
  "description": "Trade only when ADX confirms a strong trend and SuperTrend agrees direction.",
  "weights": {"model": 0.6, "ta": 0.4},
  "thresholds": {"ml_ta": 0.55, "ta_only": 0.65},
  "timeframes": {"primary": "1d", "confirmation": [], "require_alignment": false},
  "position_sizing": {"mode": "confidence_scaled", "base_cost": 500, "min_confidence": 0.2, "max_scale": 1.2},
  "risk": {
    "stop_loss_rate": 0.015,
    "take_profit_rate": 0.03,
    "max_drawdown_rate": 0.02,
    "daily_loss_limit_rate": 0.05,
    "max_open_positions": 2,
    "max_position_cost": 500.0
  },
  "gates": {
    "ta_confirmation": true,
    "trend":          {"enabled": true, "adx_min": 20.0, "require_supertrend": true, "require_higher_highs": false},
    "momentum":       {"enabled": false},
    "volume":         {"enabled": false},
    "volatility":     {"enabled": false},
    "mean_reversion": {"enabled": false},
    "news":           {"enabled": false}
  }
}
