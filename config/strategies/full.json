{
  "name": "full",
  "version": "1.0",
  "description": "All gates active: trend + momentum + volume + news + multi-timeframe. Requires TRADEX_FINNHUB_API_KEY.",
  "weights": {"model": 0.6, "ta": 0.4},
  "thresholds": {"ml_ta": 0.60, "ta_only": 0.70},
  "timeframes": {"primary": "1d", "confirmation": ["1w"], "require_alignment": true},
  "position_sizing": {"mode": "confidence_scaled", "base_cost": 500, "min_confidence": 0.35, "max_scale": 1.5},
  "gates": {
    "ta_confirmation": true,
    "trend":          {"enabled": true, "adx_min": 20.0, "require_supertrend": true, "require_higher_highs": false},
    "momentum":       {"enabled": true, "indicator": "roc", "period": 10, "min_value": 0.0},
    "volume":         {"enabled": true, "volume_ratio_min": 1.3, "require_obv_confirmation": true},
    "volatility":     {"enabled": false},
    "mean_reversion": {"enabled": false},
    "news":           {"enabled": true, "lookback_hours": 24, "cache_ttl_minutes": 60}
  }
}
