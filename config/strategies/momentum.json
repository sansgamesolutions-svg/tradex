{
  "name": "momentum",
  "version": "1.0",
  "description": "Enter only when ROC confirms positive momentum alongside TA and ML signals.",
  "weights": {"model": 0.6, "ta": 0.4},
  "thresholds": {"ml_ta": 0.56, "ta_only": 0.66},
  "timeframes": {"primary": "1d", "confirmation": [], "require_alignment": false},
  "position_sizing": {"mode": "confidence_scaled", "base_cost": 500, "min_confidence": 0.25, "max_scale": 1.3},
  "gates": {
    "ta_confirmation": true,
    "trend":          {"enabled": false},
    "momentum":       {"enabled": true, "indicator": "roc", "period": 10, "min_value": 0.0},
    "volume":         {"enabled": false},
    "volatility":     {"enabled": false},
    "mean_reversion": {"enabled": false},
    "news":           {"enabled": false}
  }
}
