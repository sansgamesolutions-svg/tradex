# Copy to .env and fill in values. Never commit .env to git.

# ── Storage ──────────────────────────────────────────────────────────────────
TRADEX_STORAGE_BACKEND=local
# TRADEX_STORAGE_BACKEND=s3

# Required when using S3 backend
# TRADEX_S3_BUCKET=my-tradex-bucket
# TRADEX_S3_PREFIX=tradex
# TRADEX_S3_ENDPOINT_URL=          # leave empty for AWS; http://minio:9000 for MinIO

# AWS credentials (or use IAM role / workload identity in cloud)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

# ── Model behaviour ───────────────────────────────────────────────────────────
TRADEX_SIGNAL_THRESHOLD=0.55
TRADEX_TA_ONLY_SIGNAL_THRESHOLD=0.65
TRADEX_MODEL_WEIGHT=0.6
TRADEX_TA_WEIGHT=0.4
TRADEX_DECISION_POLICY_VERSION=2.0
TRADEX_LOOKBACK_PERIODS=60

# ── Scheduler ─────────────────────────────────────────────────────────────────
# Comma-separated list of assets to predict daily (leave empty to disable)
TRADEX_SCHEDULE_ASSETS=
TRADEX_SCHEDULE_HOUR=9
TRADEX_SCHEDULE_MODEL=xgboost

# Interactive Brokers TWS paper trading defaults
TRADEX_IBKR_HOST=127.0.0.1
TRADEX_IBKR_PORT=7497
TRADEX_IBKR_CLIENT_ID=10
# Set directly, in .env, or point TRADEX_IBKR_ACCOUNT_FILE to a mounted secret file
# TRADEX_IBKR_ACCOUNT=
# TRADEX_IBKR_ACCOUNT_FILE=/run/secrets/tradex_ibkr_account
TRADEX_IBKR_TIMEOUT=4

# Kraken spot trading. Grant trade permission, never withdrawal permission.
# Set values directly/in .env, or use the _FILE variants for Docker/Kubernetes.
# TRADEX_KRAKEN_API_KEY=
# TRADEX_KRAKEN_API_SECRET=
# TRADEX_KRAKEN_API_KEY_FILE=/run/secrets/tradex_kraken_api_key
# TRADEX_KRAKEN_API_SECRET_FILE=/run/secrets/tradex_kraken_api_secret
TRADEX_KRAKEN_TIMEOUT=10000

# One-day internal paper-trading drill. This never sends broker orders.
TRADEX_AUTO_WORKER_ENABLED=true
TRADEX_DRILL_DATA_DIR=data/drill
TRADEX_DRILL_INITIAL_CAPITAL=5000
TRADEX_DRILL_MAX_POSITION_COST=500
TRADEX_DRILL_MAX_OPEN_POSITIONS=2
TRADEX_DRILL_STOP_LOSS_RATE=0.01
TRADEX_DRILL_TAKE_PROFIT_RATE=0.02
TRADEX_DRILL_MAX_DRAWDOWN_RATE=0.01
TRADEX_DRILL_MAX_PRICE_AGE_MINUTES=10
TRADEX_DRILL_MAX_FUTURE_SECONDS=60
TRADEX_DRILL_MIN_QUOTE_COVERAGE=0.60
TRADEX_DRILL_MAX_SYMBOL_FAILURES=3
TRADEX_DRILL_STOCK_SLIPPAGE_RATE=0.0002
TRADEX_DRILL_STOCK_FIXED_FEE=0.35
TRADEX_DRILL_CRYPTO_SLIPPAGE_RATE=0.0005
TRADEX_DRILL_CRYPTO_FEE_RATE=0.004
