# Copy this file to config.yaml to override defaults.
# config.yaml is gitignored. All keys can also be set as env vars:
# TRADEX_LOOKBACK_PERIODS=90 tradex predict ...

default_timeframe: "1d"
lookback_periods: 60
prediction_horizon: 1
train_test_split: 0.8
signal_threshold: 0.55
model_weight: 0.6
ta_weight: 0.4

# Interactive Brokers TWS paper trading defaults
ibkr_host: "127.0.0.1"
ibkr_port: 7497
ibkr_client_id: 10
ibkr_timeout: 4.0

# Kraken spot trading
kraken_timeout: 10000

# Secrets do not belong in this file. Use environment variables, an ignored
# .env file, or TRADEX_<PLATFORM>_<FIELD>_FILE mounted secret paths.

# S&P 500 stock qualification
stock_min_bars: 1250
stock_min_feature_samples: 1000
stock_min_price: 5.0
stock_min_median_dollar_volume: 25000000
stock_dollar_volume_window: 252
stock_max_missing_session_rate: 0.01
stock_max_stale_sessions: 3
stock_min_minority_class_rate: 0.35
stock_walk_forward_folds: 4
stock_walk_forward_initial_fraction: 0.60
stock_min_median_roc_auc: 0.52
stock_min_median_balanced_accuracy: 0.51
stock_min_folds_beating_baseline: 3
